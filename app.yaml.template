command:
  - gunicorn
  - app:app
env:
  - name: HOME
    value: /app/python/source_code
  - name: DATABRICKS_TOKEN
    valueFrom: DATABRICKS_TOKEN
  # Authorization mode for who may use this app:
  #   workspace  (DEFAULT) — ANY authenticated workspace user. Lab-first: each
  #              attendee gets their own isolated app instance, so this is safe
  #              and requires zero per-attendee allowlist patching.
  #   owner      — single-user: only the app owner (plus any emails in
  #              CONTROL_TOWER_AUTHORIZED_EMAILS / AUTHORIZED_EMAILS /
  #              DATABRICKS_APP_AUTHORIZED_EMAIL). Use to lock the app to yourself.
  #   allowlist  — only the explicit allowlist emails (owner also allowed when
  #              resolved). Owner resolution NOT required — good for SP-deployed
  #              apps with a known attendee set.
  # app.yaml env is authoritative at runtime — set the value HERE.
  - name: CODA_AUTH_MODE
    value: "workspace"
  - name: ANTHROPIC_MODEL
    value: databricks-claude-opus-4-6
  - name: GEMINI_MODEL
    value: databricks-gemini-2-5-pro
  - name: HERMES_MODEL
    value: databricks-claude-opus-4-7
  - name: HERMES_FALLBACK_MODEL
    value: databricks-claude-opus-4-6
  # --- Agent footprint toggles ---------------------------------------------
  # CODA_PROFILE presets the toggleable-agent defaults:
  #   lab (DEFAULT)   — lean: Claude + AppKit + Databricks core only; Codex,
  #                     OpenCode, Gemini, Hermes are OFF. Also turns on the
  #                     guided lab-coach behavior. This is the lab-first default.
  #   full            — install Claude, Codex, OpenCode, Gemini, Hermes (the
  #                     power-user build). Set this explicitly to opt out of lab.
  # An unset CODA_PROFILE resolves to "lab". scripts/lab_deploy.py also sets it.
  - name: CODA_PROFILE
    value: "lab"
  # Per-agent overrides. An explicit value here ALWAYS wins over CODA_PROFILE,
  # so they are commented out by default to let the profile govern. Uncomment to
  # force a specific agent on/off regardless of profile. (Claude, AppKit, and the
  # Databricks CLI are core and always installed.)
  # - name: ENABLE_CODEX
  #   value: "true"
  # - name: ENABLE_OPENCODE
  #   value: "true"
  # - name: ENABLE_GEMINI
  #   value: "true"
  # - name: ENABLE_HERMES
  #   value: "true"
  # Lakebase instance name used by scripts/lakebase_ensure.py when an app needs
  # persistence. Naming only — NO database is provisioned at boot; one is created
  # on demand (and reused) only when a built app actually needs it.
  - name: LAKEBASE_INSTANCE_NAME
    value: "coda-lab"
  # Claude "auto mode" — Claude's permissions.defaultMode. The lab profile
  # defaults to bypassPermissions (zero approval prompts) so attendees get a
  # smooth, hands-off build in their isolated per-workspace app container; the
  # full build stays at Claude's safe default. Override here:
  #   true / false        — force bypassPermissions on / off
  #   acceptEdits | auto | plan | dontAsk | bypassPermissions — pick a mode
  # - name: CODA_AUTO_MODE
  #   value: "true"
  #OPTIONAL: Use the new Databricks AI Gateway if you have access (recommended), otherwise it will default to the older endpoint
  - name: DATABRICKS_GATEWAY_HOST
    value: https://<your-gateway-id>.ai-gateway.<env>.cloud.databricks.com
  # NOTE: CLAUDE_CODE_DISABLE_AUTO_MEMORY=0 enables auto memory, allowing Claude Code to
  # persist context and history across sessions. This flag is temporary — once Anthropic
  # completes the rollout and auto memory is on by default, this can be removed entirely.
  - name: CLAUDE_CODE_DISABLE_AUTO_MEMORY
    value: 0
  # Set MLFLOW_TRACING_ENABLED=true to auto-trace Claude, Codex, and Gemini
  # sessions into /Users/{app_owner}/{app_name}. Default off to keep installs
  # lightweight — opt in when you want observability across all three agents.
  - name: MLFLOW_TRACING_ENABLED
    value: "false"
